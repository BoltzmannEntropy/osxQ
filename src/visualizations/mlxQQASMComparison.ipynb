   "source": [
    "# mlxQuantum QASM: Plot + Measurement Comparison (mlxq vs PennyLane)\n",
    "\n",
    "This notebook loads a QASM circuit, draws it side-by-side (mlxq vs PennyLane),\n",
    "and compares measurement histograms from both simulators.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "%matplotlib inline\n",
    "import sys, pathlib, os\n",
    "sys.path.insert(0, str(pathlib.Path().resolve().parent))  # src/python\n",
    "from mlxq.qasm import parse_qasm_file\n",
    "from mlxq.draw import circuit_mpl, circuit_ascii\n",
    "from mlxq.pretty import console\n",
    "import matplotlib.pyplot as plt\n",
    "from collections import Counter\n",
    "from io import BytesIO\n",
    "import base64\n",
    "from IPython.display import HTML, display\n",
    "\n",
    "def _fig_to_data_uri(fig):\n",
    "    buf = BytesIO()\n",
    "    fig.savefig(buf, format='png', dpi=150, bbox_inches='tight')\n",
    "    buf.seek(0)\n",
    "    return 'data:image/png;base64,' + base64.b64encode(buf.read()).decode('ascii')\n",
    "\n",
    "def side_by_side(n_qubits, ops, title=''):\n",
    "    res = circuit_mpl(n_qubits, ops, title=f'mlxq: {title}', theme='apple', rounded=True, badge=False)\n",
    "    if res is None:\n",
    "        print('matplotlib not available for mlxq drawer')\n",
    "        return\n",
    "    fig1, _ = res\n",
    "    uri1 = _fig_to_data_uri(fig1)\n",
    "    try:\n",
    "        import pennylane as qml\n",
    "        dev = qml.device('default.qubit', wires=n_qubits)\n",
    "        # Map ops to PennyLane for drawing\n",
    "        def _apply(op):\n",
    "            name = op['name']\n",
    "            w = op['wires']\n",
    "            p = op.get('parameters', [])\n",
    "            m = {\n",
    "                'H': lambda: qml.Hadamard(wires=w[0]),\n",
    "                'X': lambda: qml.PauliX(wires=w[0]),\n",
    "                'Y': lambda: qml.PauliY(wires=w[0]),\n",
    "                'Z': lambda: qml.PauliZ(wires=w[0]),\n",
    "                'RX': lambda: qml.RX(p[0] if p else 0.0, wires=w[0]),\n",
    "                'RY': lambda: qml.RY(p[0] if p else 0.0, wires=w[0]),\n",
    "                'RZ': lambda: qml.RZ(p[0] if p else 0.0, wires=w[0]),\n",
    "                'CNOT': lambda: qml.CNOT(wires=tuple(w)),\n",
    "                'CZ': lambda: qml.CZ(wires=tuple(w)),\n",
    "                'SWAP': lambda: qml.SWAP(wires=tuple(w)),\n",
    "                'CCX': lambda: qml.Toffoli(wires=tuple(w)),\n",
    "                'CRX': lambda: qml.CRX(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CRY': lambda: qml.CRY(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CRZ': lambda: qml.CRZ(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CPHASE': lambda: qml.ControlledPhaseShift(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CP': lambda: qml.ControlledPhaseShift(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'I': lambda: qml.Identity(wires=w[0]),\n",
    "            }\n",
    "            if name in m:\n",
    "                m[name]()\n",
    "            elif name == 'U3':\n",
    "                th, ph, la = (p + [0.0,0.0,0.0])[:3]\n",
    "                qml.RZ(ph, wires=w[0]); qml.RY(th, wires=w[0]); qml.RZ(la, wires=w[0])\n",
    "            elif name == 'U2':\n",
    "                ph, la = (p + [0.0,0.0])[:2]\n",
    "                qml.RZ(ph, wires=w[0]); qml.RY(1.57079632679, wires=w[0]); qml.RZ(la, wires=w[0])\n",
    "            elif name == 'U1':\n",
    "                la = (p + [0.0])[0]\n",
    "                qml.RZ(la, wires=w[0])\n",
    "        @qml.qnode(dev)
    "        def _pl_draw():
    "            for op in ops:
    "                _apply(op)
    "            return qml.state()
    "        fig2, _ = qml.draw_mpl(_pl_draw)()
    "        uri2 = _fig_to_data_uri(fig2)
    "        html = f\"\"\"\n",
    "        <div style='display:flex; gap:16px; align-items:flex-start'>\n",
    "          <div style='flex:1'><img style='max-width:100%' src='{uri1}'/></div>\n",
    "          <div style='flex:1'><img style='max-width:100%' src='{uri2}'/></div>\n",
    "        </div>\n",
    "        \"\"\"\n",
    "        display(HTML(html))
    "        try:
    "            plt.close(fig1); plt.close(fig2)
    "        except Exception:
    "            pass
    "    except Exception as e:\n",
    "        html = f\"<div><img style='max-width:100%' src='{uri1}'/></div>\"\n",
    "        display(HTML(html))\n",
    "        try:\n",
    "            plt.close(fig1)\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "def compare_counts(n_qubits, ops, shots=1000):\n",
    "    # mlxq counts\n",
    "    mlx_counts = None\n",
    "    try:\n",
    "        from mlxq.device import Device\n",
    "        dev = Device(n_qubits)\n",
    "        dev.execute(ops)\n",
    "        mlx_counts = dev.sim.sample_counts(shots)\n",
    "    except Exception as e:\n",
    "        print('mlxq device not available; skipping mlxq measurement:', e)\n",
    "\n",
    "    # PennyLane counts\n",
    "    pl_counts = None\n",
    "    try:\n",
    "        import pennylane as qml\n",
    "        dev2 = qml.device('default.qubit', wires=n_qubits, shots=shots)\n",
    "        def _apply(op):\n",
    "            name = op['name']\n",
    "            w = op['wires']\n",
    "            p = op.get('parameters', [])\n",
    "            m = {\n",
    "                'H': lambda: qml.Hadamard(wires=w[0]),\n",
    "                'X': lambda: qml.PauliX(wires=w[0]),\n",
    "                'Y': lambda: qml.PauliY(wires=w[0]),\n",
    "                'Z': lambda: qml.PauliZ(wires=w[0]),\n",
    "                'RX': lambda: qml.RX(p[0] if p else 0.0, wires=w[0]),\n",
    "                'RY': lambda: qml.RY(p[0] if p else 0.0, wires=w[0]),\n",
    "                'RZ': lambda: qml.RZ(p[0] if p else 0.0, wires=w[0]),\n",
    "                'CNOT': lambda: qml.CNOT(wires=tuple(w)),\n",
    "                'CZ': lambda: qml.CZ(wires=tuple(w)),\n",
    "                'SWAP': lambda: qml.SWAP(wires=tuple(w)),\n",
    "                'CCX': lambda: qml.Toffoli(wires=tuple(w)),\n",
    "                'CRX': lambda: qml.CRX(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CRY': lambda: qml.CRY(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CRZ': lambda: qml.CRZ(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CPHASE': lambda: qml.ControlledPhaseShift(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'CP': lambda: qml.ControlledPhaseShift(p[0] if p else 0.0, wires=tuple(w)),\n",
    "                'I': lambda: qml.Identity(wires=w[0]),\n",
    "            }\n",
    "            if name in m:\n",
    "                m[name]()\n",
    "            elif name == 'U3':\n",
    "                th, ph, la = (p + [0.0,0.0,0.0])[:3]\n",
    "                qml.RZ(ph, wires=w[0]); qml.RY(th, wires=w[0]); qml.RZ(la, wires=w[0])\n",
    "            elif name == 'U2':\n",
    "                ph, la = (p + [0.0,0.0])[:2]\n",
    "                qml.RZ(ph, wires=w[0]); qml.RY(1.57079632679, wires=w[0]); qml.RZ(la, wires=w[0])\n",
    "            elif name == 'U1':\n",
    "                la = (p + [0.0])[0]\n",
    "                qml.RZ(la, wires=w[0])\n",
    "        @qml.qnode(dev2)\n",
    "        def _pl_sample():\n",
    "            for op in ops:\n",
    "                _apply(op)\n",
    "            return qml.sample()\n",
    "        samp = _pl_sample()\n",
    "        bitstrings = [''.join(str(int(b)) for b in row) for row in samp]\n",
    "        pl_counts = dict(Counter(bitstrings))\n",
    "    except Exception as e:\n",
    "        print('PennyLane not available; skipping PL measurement:', e)\n",
    "\n",
    "    return mlx_counts, pl_counts\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Choose a QASM file present under datasets/qasm/local\n",
    "qasm_name = 'qft_n4.qasm'  # try also: 'bell.qasm', 'inverseqft_n4.qasm'\n",
    "n, ops = parse_qasm_file(f'datasets/qasm/local/{qasm_name}')\n",
    "print(circuit_ascii(n, ops))\n",
    "side_by_side(n, ops, title=f'QASM: {qasm_name}')\n",
    "\n",
    "shots = 1000\n",
    "mlx_counts, pl_counts = compare_counts(n, ops, shots=shots)\n",
    "\n",
    "print(f'Counts (top 10), shots={shots}')\n",
    "if mlx_counts is not None:\n",
    "    print('mlxq: ', dict(sorted(mlx_counts.items(), key=lambda kv: kv[1], reverse=True)[:10]))\n",
    "if pl_counts is not None:\n",
    "    print('pennylane: ', dict(sorted(pl_counts.items(), key=lambda kv: kv[1], reverse=True)[:10]))\n"
   ]
  }
 ],
